# ─────────────────────────────────────────────────────────────
# LearnHub Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets to git.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon, Supabase, or your own) ─────────────────
DB_URL=jdbc:postgresql://your-host/your-db?sslmode=require
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ── Gmail SMTP (use an App Password, not your real password) ──
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_google_app_password

# ── AWS / Cloudflare R2 Object Storage ───────────────────────
AWS_ACCESS_KEY=your_access_key_id
AWS_SECRET_KEY=your_secret_access_key
AWS_REGION=auto
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_BUCKET=your-bucket-name
AWS_PUBLIC_URL=https://pub-XXXX.r2.dev

# ── Stripe (leave as dummy if not using payments) ─────────────
STRIPE_PUBLIC_KEY=pk_test_dummy
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=dummy

# ── Frontend URL (used in CORS + email links) ─────────────────
FRONTEND_URL=https://yourdomain.com

# ── Spring Active Profile ─────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
