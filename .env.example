# ── Database (Neon PostgreSQL or any Postgres) ─────────────────────────
DB_URL=jdbc:postgresql://ep-snowy-wave-am08muol.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_db_password

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── Gmail SMTP ──────────────────────────────────────────────────────────
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# ── AWS / Cloudflare R2 Storage ─────────────────────────────────────────
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
AWS_REGION=auto
AWS_ENDPOINT=https://your-account.r2.cloudflarestorage.com
AWS_S3_BUCKET=your-bucket-name
AWS_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Stripe (optional) ───────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_dummy
STRIPE_SECRET_KEY=sk_test_dummy
